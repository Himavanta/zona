{
  "scopeName": "source.zona",
  "name": "Zona",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#definition" },
    { "include": "#return" },
    { "include": "#conditional" },
    { "include": "#loop" },
    { "include": "#use" },
    { "include": "#primitive" },
    { "include": "#arithmetic" },
    { "include": "#comparison" },
    { "include": "#print" },
    { "include": "#memory-op" }
  ],
  "repository": {
    "comment": {
      "match": "_.*$",
      "name": "comment.line.zona"
    },
    "string": {
      "begin": "'",
      "end": "'",
      "name": "string.quoted.single.zona",
      "patterns": [{
        "match": "\\\\.",
        "name": "constant.character.escape.zona"
      }]
    },
    "number": {
      "match": "(?<=\\s|^)-?[0-9]+(\\.[0-9]+)?(?=\\s|$)",
      "name": "constant.numeric.zona"
    },
    "definition": {
      "patterns": [
        { "match": "@", "name": "keyword.control.define.zona" },
        { "match": ";", "name": "keyword.control.end.zona" }
      ]
    },
    "return": {
      "match": "\\$",
      "name": "keyword.control.return.zona"
    },
    "conditional": {
      "match": "[?!]",
      "name": "keyword.control.conditional.zona"
    },
    "loop": {
      "match": "~",
      "name": "keyword.control.loop.zona"
    },
    "use": {
      "match": ":use",
      "name": "keyword.control.import.zona"
    },
    "primitive": {
      "match": ":[a-z]+",
      "name": "support.function.builtin.zona"
    },
    "arithmetic": {
      "match": "[+\\-*/%^]",
      "name": "keyword.operator.arithmetic.zona"
    },
    "comparison": {
      "match": "[><=]",
      "name": "keyword.operator.comparison.zona"
    },
    "print": {
      "match": "\\.",
      "name": "keyword.operator.print.zona"
    },
    "memory-op": {
      "match": "[&#]",
      "name": "keyword.operator.memory.zona"
    }
  }
}
