_ ============================================
_ Zona V2 综合测试
_ ============================================

_ --- 整数算术 ---
3 5 + .
10 4 - .
6 7 * .
20 3 / .
17 5 % .
2 10 ^ .

_ --- 浮点算术 ---
3.0 5.0 + .
10.0 4.0 - .
6.0 7.0 * .
20.0 3.0 / .
2.0 10.0 ^ .

_ --- 比较 ---
3 5 < .
5 3 > .
3 3 = .
3.0 5.0 < .

_ --- 栈操作 ---
1 2 :swap . .
3 :dup . .
4 5 :drop .
1 2 3 :rot . . .

_ --- 栈效应验证 ---
@ add1 l:l 1 + ;
3 add1 .

@ neg d:d 0.0 :swap - ;
@ abs d:d :dup 0.0 < ? neg ! ;
-3.0 abs .
3.0 abs .

_ --- 控制流 ---
@ countdown l: :dup 0 = ? $ :dup . 1 - ~ ;
3 countdown

_ --- 递归 fib ---
@ fib d:d :dup 2.0 < ? $ :dup 1.0 - fib :swap 2.0 - fib + ;
10.0 fib .
35.0 fib .

_ --- 字符串 ---
'hello zona' :type 10 :emit

_ --- 内存 ---
8 :alloc :dup 42 :swap # :dup & . :free

_ --- 调试 ---
:stack
:words

_ --- 系统 ---
:time .
10 :rand .
:argc .

_ 完成
'OK' :type 10 :emit
