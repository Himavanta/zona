_ ============================================
_ Zona V2 综合测试
_ ============================================

_ --- 整数算术 ---
3 5 + :print
10 4 - :print
6 7 * :print
20 3 / :print
17 5 % :print
2 10 ^ :print

_ --- 浮点算术 ---
3.0 5.0 + :print
10.0 4.0 - :print
6.0 7.0 * :print
20.0 3.0 / :print
2.0 10.0 ^ :print

_ --- 比较 ---
3 5 < :print
5 3 > :print
3 3 = :print
3.0 5.0 < :print

_ --- 栈操作 ---
1 2 :swap :print :print
3 :dup :print :print
4 5 :drop :print
1 2 3 :rot :print :print :print

_ --- 栈效应验证 ---
@ add1 l:l 1 + ;
3 add1 :print

@ neg d:d 0.0 :swap - ;
@ abs d:d :dup 0.0 < ? neg ! ;
-3.0 abs :print
3.0 abs :print

_ --- 控制流 ---
@ countdown l: :dup 0 = ? $ :dup :print 1 - ~ ;
3 countdown

_ --- 递归 fib ---
@ fib d:d :dup 2.0 < ? $ :dup 1.0 - fib :swap 2.0 - fib + ;
10.0 fib :print
35.0 fib :print

_ --- 字符串 ---
'hello zona' :type 10 :emit

_ --- 内存 ---
8 :alloc :dup 42 :swap # :dup & :print :free

_ --- 调试 ---
:stack
:words

_ --- 系统 ---
:time :print
10 :rand :print
:argc :print

_ 完成
'OK' :type 10 :emit
