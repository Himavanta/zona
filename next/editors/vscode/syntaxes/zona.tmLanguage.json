{
  "scopeName": "source.zona",
  "name": "Zona",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#word-name" },
    { "include": "#definition-end" },
    { "include": "#compile-directive" },
    { "include": "#primitive" },
    { "include": "#sig-separator" },
    { "include": "#sig-types" },
    { "include": "#return" },
    { "include": "#conditional" },
    { "include": "#loop" },
    { "include": "#member-access" },
    { "include": "#print" },
    { "include": "#arithmetic" },
    { "include": "#comparison" },
    { "include": "#memory-op" }
  ],
  "repository": {
    "comment": {
      "match": "_.*$",
      "name": "comment.line.zona"
    },
    "string": {
      "begin": "'",
      "end": "'",
      "name": "string.quoted.single.zona",
      "patterns": [{
        "match": "\\\\.",
        "name": "constant.character.escape.zona"
      }]
    },
    "number": {
      "match": "(?<=\\s|^)-?[0-9]+(\\.[0-9]+)?(?=\\s|$)",
      "name": "constant.numeric.zona"
    },
    "word-name": {
      "match": "@\\s+([a-zA-Z][a-zA-Z0-9]*)",
      "captures": {
        "0": { "name": "keyword.control.define.zona" },
        "1": { "name": "entity.name.function.zona" }
      }
    },
    "definition-end": {
      "match": ";",
      "name": "keyword.control.end.zona"
    },
    "compile-directive": {
      "match": ":(?:use|bind|struct)\\b",
      "name": "keyword.control.directive.zona"
    },
    "primitive": {
      "match": ":[a-z]+",
      "name": "support.function.builtin.zona"
    },
    "sig-separator": {
      "match": "(?<=[ldp]):(?=[ldp]|\\s|$)",
      "name": "keyword.operator.sig-separator.zona"
    },
    "sig-types": {
      "match": "(?<=^|\\s)[ldp]+(?=\\s|:|;|$|@)",
      "name": "storage.type.zona"
    },
    "return": {
      "match": "\\$",
      "name": "keyword.control.return.zona"
    },
    "conditional": {
      "match": "[?!]",
      "name": "keyword.control.conditional.zona"
    },
    "loop": {
      "match": "~",
      "name": "keyword.control.loop.zona"
    },
    "member-access": {
      "match": "\\.(?=[a-zA-Z])",
      "name": "keyword.operator.member.zona"
    },
    "print": {
      "match": "\\.(?=\\s|$)",
      "name": "keyword.operator.print.zona"
    },
    "arithmetic": {
      "match": "[+\\-*/%^]",
      "name": "keyword.operator.arithmetic.zona"
    },
    "comparison": {
      "match": "[><=]",
      "name": "keyword.operator.comparison.zona"
    },
    "memory-op": {
      "match": "[&#]",
      "name": "keyword.operator.memory.zona"
    }
  }
}
